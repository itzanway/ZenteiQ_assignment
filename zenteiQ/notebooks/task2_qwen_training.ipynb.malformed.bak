      "\u001b[36mCell\u001b[39m\u001b[36m \u001b[39m\u001b[32mIn[4]\u001b[39m\u001b[32m, line 29\u001b[39m\n\u001b[32m     25\u001b[39m    ]\n\u001b[32m     26\u001b[39m   },\n\u001b[32m     27\u001b[39m   {\n\u001b[32m     28\u001b[39m    \u001b[33m\"cell_type\"\u001b[39m: \u001b[33m\"code\"\u001b[39m,\n\u001b[32m---> \u001b[39m\u001b[32m29\u001b[39m    \u001b[33m\"execution_count\"\u001b[39m: null,\n\u001b[32m     30\u001b[39m    \u001b[33m\"metadata\"\u001b[39m: {},\n\u001b[32m     31\u001b[39m    \u001b[33m\"outputs\"\u001b[39m: [],\n\u001b[32m     32\u001b[39m    \"source\": [\n",
