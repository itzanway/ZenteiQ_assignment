   ],
   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Task 2 — Qwen Dense Model Training (MaxText)\\n\",\n",
    "    \"\\n\",\n",
    "    \"This notebook runs **Qwen3-0.6B (base)** and a **scaled-up ~1B variant** for 50 steps each, on **CPU**, **GPU**, and **TPU** Colab runtimes.\\n\",\n",
    "    \"\\n\",\n",
    "    \"### How to use this notebook\\n\",\n",
    "    \"1. Set **Runtime > Change runtime type** to `CPU`, run all cells, download `results_cpu/`.\\n\",\n",
    "    \"2. Switch to `T4 GPU`, restart runtime, run all cells again, download `results_gpu/`.\\n\",\n",
    "    \"3. Switch to `TPU v2-8` (or whatever TPU is offered), restart runtime, run all cells again, download `results_tpu/`.\\n\",\n",
    "    \"4. Copy all three `results_*` folders into the repo's `results/` directory.\\n\",\n",
    "    \"\\n\",\n",
    "    \"Each run is fully self-contained (re-clones MaxText, re-installs deps) so it works independently of which backend Colab gives you.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 0. Detect backend\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import subprocess, os, sys\\n\",\n",
    "    \"\\n\",\n",
    "    \"def detect_backend():\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        subprocess.run(['nvidia-smi'], check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)\\n\",\n",
    "    \"        return 'gpu'\\n\",\n",
    "    \"    except Exception:\\n\",\n",
    "    \"        pass\\n\",\n",
    "    \"    if 'COLAB_TPU_ADDR' in os.environ or 'TPU_NAME' in os.environ:\\n\",\n",
    "    \"        return 'tpu'\\n\",\n",
    "    \"    return 'cpu'\\n\",\n",
    "    \"\\n\",\n",
    "    \"BACKEND = detect_backend()\\n\",\n",
    "    \"print(f'Detected backend: {BACKEND}')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 1. Install MaxText (backend-specific)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"!git clone -q https://github.com/AI-Hypercomputer/maxtext.git\\n\",\n",
    "    \"%cd maxtext\\n\",\n",
    "    \"\\n\",\n",
    "    \"if BACKEND == 'tpu':\\n\",\n",
    "    \"    !pip install -q -e \\\".[tpu]\\\"\\n\",\n",
    "    \"elif BACKEND == 'gpu':\\n\",\n",
    "    \"    !pip install -q -e \\\".[gpu]\\\"\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    !pip install -q -e \\\".\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"print('Install complete for backend:', BACKEND)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Sanity check: confirm JAX sees the expected devices\\n\",\n",
    "    \"import jax\\n\",\n",
    "    \"print('JAX devices:', jax.devices())\\n\",\n",
    "    \"print('JAX backend:', jax.default_backend())\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 2. Write configs\\n\",\n",
    "    \"\\n\",\n",
    "    \"We inline the configs here (mirrors `configs/qwen/*.yml` in the repo) so the notebook is fully standalone.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"qwen_06b_overrides = dict(\\n\",\n",
    "    \"    model_name='qwen3-0.6b',\\n\",\n",
    "    \"    steps=50,\\n\",\n",
    "    \"    dataset_type='synthetic',\\n\",\n",
    "    \"    per_device_batch_size=1,\\n\",\n",
    "    \"    max_target_length=512,\\n\",\n",
    "    \"    learning_rate=3e-4,\\n\",\n",
    "    \"    dtype='bfloat16',\\n\",\n",
    "    \"    weight_dtype='bfloat16',\\n\",\n",
    "    \"    enable_checkpointing=False,\\n\",\n",
    "    \"    attention='dot_product',\\n\",\n",
    "    \"    tokenizer_type='huggingface',\\n\",\n",
    "    \"    tokenizer_path='Qwen/Qwen3-0.6B',\\n\",\n",
    "    \"    log_period=1,\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Scaled-up ~1B: wider emb_dim + mlp_dim, same Qwen3 block, fewer layers\\n\",\n",
    "    \"# See configs/qwen/qwen3_1b_train.yml for full justification.\\n\",\n",
    "    \"qwen_1b_overrides = dict(\\n\",\n",
    "    \"    model_name='qwen3-0.6b',\\n\",\n",
    "    \"    base_emb_dim=1536,\\n\",\n",
    "    \"    base_num_query_heads=16,\\n\",\n",
    "    \"    base_num_kv_heads=8,\\n\",\n",
    "    \"    base_mlp_dim=4096,\\n\",\n",
    "    \"    base_num_decoder_layers=24,\\n\",\n",
    "    \"    head_dim=96,\\n\",\n",
    "    \"    steps=50,\\n\",\n",
    "    \"    dataset_type='synthetic',\\n\",\n",
    "    \"    per_device_batch_size=1,\\n\",\n",
    "    \"    max_target_length=512,\\n\",\n",
    "    \"    learning_rate=3e-4,\\n\",\n",
    "    \"    dtype='bfloat16',\\n\",\n",
    "    \"    weight_dtype='bfloat16',\\n\",\n",
    "    \"    enable_checkpointing=False,\\n\",\n",
    "    \"    attention='dot_product',\\n\",\n",
    "    \"    tokenizer_type='huggingface',\\n\",\n",
    "    \"    tokenizer_path='Qwen/Qwen3-0.6B',\\n\",\n",
    "    \"    log_period=1,\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print('Configs ready.')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 3. Helper to run training and capture full logs\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import subprocess, time, os, json, re\\n\",\n",
    "    \"\\n\",\n",
    "    \"RESULTS_DIR = f'/content/results_{BACKEND}'\\n\",\n",
    "    \"os.makedirs(RESULTS_DIR, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"def run_training(run_name, overrides, log_filename):\\n\",\n",
    "    \"    args = [f'{k}={v}' for k, v in overrides.items()]\\n\",\n",
    "    \"    args.append(f'base_output_directory=/content/maxtext_output')\\n\",\n",
    "    \"    args.append(f'run_name={run_name}')\\n\",\n",
    "    \"\\n\",\n",
    "    \"    cmd = ['python', '-m', 'maxtext.train', 'src/maxtext/configs/base.yml'] + args\\n\",\n",
    "    \"    print('Running:', ' '.join(cmd))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    log_path = os.path.join(RESULTS_DIR, log_filename)\\n\",\n",
    "    \"    start = time.time()\\n\",\n",
    "    \"    with open(log_path, 'w') as f:\\n\",\n",
    "    \"        proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)\\n\",\n",
    "    \"        for line in proc.stdout:\\n\",\n",
    "    \"            print(line, end='')\\n\",\n",
    "    \"            f.write(line)\\n\",\n",
    "    \"        proc.wait()\\n\",\n",
    "    \"    elapsed = time.time() - start\\n\",\n",
    "    \"    print(f'\\\\n=== Finished {run_name} in {elapsed:.1f}s, exit code {proc.returncode} ===')\\n\",\n",
    "    \"    return log_path, elapsed, proc.returncode\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 4. Run A — Qwen 0.6B base\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"log_path_06b, wall_time_06b, exit_code_06b = run_training(\\n\",\n",
    "    \"    run_name=f'qwen_0.6b_{BACKEND}',\\n\",\n",
    "    \"    overrides=qwen_06b_overrides,\\n\",\n",
    "    \"    log_filename=f'qwen_0.6b_{BACKEND}_log.txt'\\n\",\n",
    "    \")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 5. Run B — Qwen ~1B scaled-up\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"log_path_1b, wall_time_1b, exit_code_1b = run_training(\\n\",\n",
    "    \"    run_name=f'qwen_1b_{BACKEND}',\\n\",\n",
    "    \"    overrides=qwen_1b_overrides,\\n\",\n",
    "    \"    log_filename=f'qwen_1b_{BACKEND}_log.txt'\\n\",\n",
    "    \")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 6. Parse metrics out of the logs\\n\",\n",
    "    \"\\n\",\n",
    "    \"MaxText logs per-step metrics to stdout in a parseable format and also writes a `metrics.json`-style trace. We extract every numeric field reported (loss, step time, TFLOPS/s, tokens/s, learning rate, gradient norm, memory) — **no metric is selectively dropped.**\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import re, pandas as pd\\n\",\n",
    "    \"\\n\",\n",
    "    \"METRIC_PATTERNS = {\\n\",\n",
    "    \"    'step': r'completed step:\\\\s*(\\\\d+)',\\n\",\n",
    "    \"    'loss': r'loss:\\\\s*([\\\\d.]+)',\\n\",\n",
    "    \"    'step_time_s': r'step_time_seconds:\\\\s*([\\\\d.]+)|seconds:\\\\s*([\\\\d.]+)',\\n\",\n",
    "    \"    'tflops_per_sec': r'TFLOP/s/device:\\\\s*([\\\\d.]+)|tflops_per_sec:\\\\s*([\\\\d.]+)',\\n\",\n",
    "    \"    'tokens_per_sec': r'tokens/s/device:\\\\s*([\\\\d.]+)|tokens_per_second:\\\\s*([\\\\d.]+)',\\n\",\n",
    "    \"    'learning_rate': r'learning[_/]rate:\\\\s*([\\\\d.eE+-]+)',\\n\",\n",
    "    \"    'grad_norm': r'grad[_ ]norm:\\\\s*([\\\\d.]+)',\\n\",\n",
    "    \"    'param_norm': r'param[_ ]norm:\\\\s*([\\\\d.]+)',\\n\",\n",
    "    \"    'perplexity': r'perplexity:\\\\s*([\\\\d.]+)',\\n\",\n",
    "    \"    'memory_gb': r'memory.*?:\\\\s*([\\\\d.]+)\\\\s*GB',\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"def parse_log(path):\\n\",\n",
    "    \"    rows = []\\n\",\n",
    "    \"    with open(path) as f:\\n\",\n",
    "    \"        text = f.read()\\n\",\n",
    "    \"    # Split roughly by step-completion lines; fallback: scan line by line and accumulate\\n\",\n",
    "    \"    lines = text.splitlines()\\n\",\n",
    "    \"    current = {}\\n\",\n",
    "    \"    for line in lines:\\n\",\n",
    "    \"        for key, pattern in METRIC_PATTERNS.items():\\n\",\n",
    "    \"            m = re.search(pattern, line)\\n\",\n",
    "    \"            if m:\\n\",\n",
    "    \"                val = next((g for g in m.groups() if g is not None), None)\\n\",\n",
    "    \"                if val is not None:\\n\",\n",
    "    \"                    current[key] = float(val) if key != 'step' else int(val)\\n\",\n",
    "    \"        if 'completed step' in line and current:\\n\",\n",
    "    \"            rows.append(current.copy())\\n\",\n",
    "    \"    return pd.DataFrame(rows)\\n\",\n",
    "    \"\\n\",\n",
    "    \"df_06b = parse_log(log_path_06b)\\n\",\n",
    "    \"df_1b = parse_log(log_path_1b)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print('Qwen 0.6B parsed rows:', len(df_06b))\\n\",\n",
    "    \"print('Qwen 1B parsed rows:', len(df_1b))\\n\",\n",
    "    \"df_06b.tail()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Save parsed metrics as CSV for the comparison table in analysis/final_summary.md\\n\",\n",
    "    \"df_06b.to_csv(os.path.join(RESULTS_DIR, f'qwen_0.6b_{BACKEND}_metrics.csv'), index=False)\\n\",\n",
    "    \"df_1b.to_csv(os.path.join(RESULTS_DIR, f'qwen_1b_{BACKEND}_metrics.csv'), index=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"summary = {\\n\",\n",
    "    \"    'backend': BACKEND,\\n\",\n",
    "    \"    'qwen_0.6b': {\\n\",\n",
    "    \"        'wall_time_total_s': wall_time_06b,\\n\",\n",
    "    \"        'exit_code': exit_code_06b,\\n\",\n",
    "    \"        'avg_step_time_s': df_06b['step_time_s'].mean() if 'step_time_s' in df_06b else None,\\n\",\n",
    "    \"        'final_loss': df_06b['loss'].iloc[-1] if 'loss' in df_06b and len(df_06b) else None,\\n\",\n",
    "    \"        'avg_tflops_per_sec': df_06b['tflops_per_sec'].mean() if 'tflops_per_sec' in df_06b else None,\\n\",\n",
    "    \"        'avg_tokens_per_sec': df_06b['tokens_per_sec'].mean() if 'tokens_per_sec' in df_06b else None,\\n\",\n",
    "    \"    },\\n\",\n",
    "    \"    'qwen_1b': {\\n\",\n",
    "    \"        'wall_time_total_s': wall_time_1b,\\n\",\n",
    "    \"        'exit_code': exit_code_1b,\\n\",\n",
    "    \"        'avg_step_time_s': df_1b['step_time_s'].mean() if 'step_time_s' in df_1b else None,\\n\",\n",
    "    \"        'final_loss': df_1b['loss'].iloc[-1] if 'loss' in df_1b and len(df_1b) else None,\\n\",\n",
    "    \"        'avg_tflops_per_sec': df_1b['tflops_per_sec'].mean() if 'tflops_per_sec' in df_1b else None,\\n\",\n",
    "    \"        'avg_tokens_per_sec': df_1b['tokens_per_sec'].mean() if 'tokens_per_sec' in df_1b else None,\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"with open(os.path.join(RESULTS_DIR, f'summary_{BACKEND}.json'), 'w') as f:\\n\",\n",
    "    \"    json.dump(summary, f, indent=2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(json.dumps(summary, indent=2))\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 7. Download results\\n\",\n",
    "    \"\\n\",\n",
    "    \"Run this cell, download the zip, then unzip it into `results/qwen_0_6b/` and `results/qwen_1b/` in the repo (matched to this backend).\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import shutil\\n\",\n",
    "    \"from google.colab import files\\n\",\n",
    "    \"\\n\",\n",
    "    \"zip_path = f'/content/results_{BACKEND}'\\n\",\n",
    "    \"shutil.make_archive(zip_path, 'zip', RESULTS_DIR)\\n\",\n",
    "    \"files.download(zip_path + '.zip')\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"---\\n\",\n",
    "    \"### Next step\\n\",\n",
    "    \"\\n\",\n",
    "    \"Re-run this entire notebook after switching **Runtime > Change runtime type** to the next backend (CPU → GPU → TPU, in any order), so you accumulate `results_cpu/`, `results_gpu/`, `results_tpu/` for both Qwen 0.6B and Qwen 1B.\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
    " \"metadata\": {\n",
    "  \"accelerator\": \"GPU\",\n",
    "  \"colab\": {\n",
    "   \"name\": \"task2_qwen_training.ipynb\",\n",
    "   \"provenance\": []\n",
    "  },\n",
    "  \"kernelspec\": {\n",
    "   \"display_name\": \"Python 3\",\n",
    "   \"name\": \"python3\"\n",
    "  },\n",
    "  \"language_info\": {\n",
    "   \"name\": \"python\"\n",
    "  }\n",
    " },\n",
    " \"nbformat\": 4,\n",
    " \"nbformat_minor\": 0\n",
    "}\n"
   ]
  }
 ],
